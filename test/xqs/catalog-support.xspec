<?xml version="1.0" encoding="UTF-8"?>
<x:description xmlns:mirror="x-urn:test:mirror" xmlns:svrl="http://purl.oclc.org/dsdl/svrl"
    xmlns:x="http://www.jenitennison.com/xslt/xspec"
    schematron="catalog-xqs:/schematron-via-catalog-xqs.sch">
    <x:import href="catalog-xqs:/test-via-catalog.xspec"/>
    <x:helper query="x-urn:test:mirror" query-at="catalog-xqs:/../../mirror.xqm"/>
    <x:scenario label="Outermost element of external document should fire">
        <x:context href="catalog-destination/document.xml"/>
        <x:expect-report id="element-fired"/>
    </x:scenario>
    <x:scenario label="Helper module referenced via catalog is usable">
        <x:call function="mirror:true"/>
        <x:expect label="and helper function returns true" select="true()"/>
    </x:scenario>
</x:description>
